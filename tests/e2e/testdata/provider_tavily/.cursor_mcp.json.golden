{
  "mcpServers": {
    "tavily": {
      "_usync": {
        "at": "{{TIMESTAMP}}",
        "managedBy": "usync",
        "planID": ""
      },
      "args": [
        "-y",
        "tavily-mcp@latest"
      ],
      "command": "npx",
      "env": {
        "TAVILY_API_KEY": "tvly-1234567890"
      }
    }
  }
}
