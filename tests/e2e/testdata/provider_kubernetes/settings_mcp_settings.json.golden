{
  "mcpServers": {
    "kubernetes": {
      "_usync": {
        "at": "{{TIMESTAMP}}",
        "managedBy": "usync",
        "planID": ""
      },
      "args": [
        "-y",
        "kubernetes-mcp-server@latest",
        "--read-only"
      ],
      "command": "npx",
      "type": "stdio"
    }
  }
}
