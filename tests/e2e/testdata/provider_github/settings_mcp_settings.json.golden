{
  "mcpServers": {
    "github": {
      "_usync": {
        "at": "{{TIMESTAMP}}",
        "managedBy": "usync",
        "planID": ""
      },
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "command": "npx",
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "ghp_1234567890"
      },
      "type": "stdio"
    }
  }
}
