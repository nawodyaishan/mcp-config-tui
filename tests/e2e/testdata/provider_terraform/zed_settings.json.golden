{
  "context_servers": {
    "terraform": {
      "_usync": {
        "at": "{{TIMESTAMP}}",
        "managedBy": "usync",
        "planID": ""
      },
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "ENABLE_TF_OPERATIONS=false",
        "hashicorp/terraform-mcp-server:0.5.2"
      ],
      "command": "docker"
    }
  }
}
